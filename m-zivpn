################################################################################
#                    LOGIC UNTUK MEMBUAT AKUN UDP ZIVPN                         #
################################################################################
function _create_account_logic() {
    data=$(curl -s ipinfo.io)
    isp=$(echo $data | jq -r '.org')
    local password="$1"           # Password akun baru
    local days="$2"                # Masa aktif dalam hari
    local db_file="/etc/zivpn/users.db"
    data=$(curl -s ipinfo.io)
    isp=$(echo $data | jq -r '.org')

    # Validasi input
    if [ -z "$password" ] || [ -z "$days" ]; then
        echo "Error: Password and days are required."
        return 1
    fi

    # Validasi bahwa days adalah angka
    if ! [[ "$days" =~ ^[0-9]+$ ]]; then
        echo "Error: Invalid number of days."
        return 1
    fi

    # Cek apakah password sudah ada
    if grep -q "^${password}:" "$db_file"; then
        echo "Error: Password '${password}' already exists."
        return 1
    fi

    # Hitung tanggal kadaluarsa (timestamp)
    local expiry_date
    expiry_date=$(date -d "+$days days" +%s)

    # Simpan akun baru ke database
    echo "${password}:${expiry_date}" >> "$db_file"

    # Update config.json dengan jq
    jq --arg pass "$password" '.auth.config += [$pass]' /etc/zivpn/config.json \
       > /etc/zivpn/config.json.tmp && mv /etc/zivpn/config.json.tmp /etc/zivpn/config.json

    if [ $? -eq 0 ]; then
        # Restart service ZIVPN agar akun baru aktif
        restart_zivpn

        # Format tanggal kadaluarsa untuk ditampilkan
        local EXPIRE_FORMATTED
        EXPIRE_FORMATTED=$(date -d "@$expiry_date" +"%d %B %Y %H:%M")

        # Ambil info host, IP, ISP, dan certificate
        local ip isp CERT_CN host
        ip=$(cat /etc/zivpn/ip.txt)
        isp=$(cat /etc/zivpn/isp.txt)
        CERT_CN=$(openssl x509 -in /etc/zivpn/zivpn.crt -noout -subject | sed -n 's/.*CN = \([^,]*\).*/\1/p')
        if [ "$CERT_CN" == "zivpn" ]; then
            host="$ip"
        else
            host="$CERT_CN"
        fi

        # Tampilkan info akun baru ke layar
        clear
        DOMAINZIV=$(cat /etc/xray/domain)
        echo "==================================="
        echo "           UDP ZIVPN CREATE            "        
        echo "==================================="        
        echo "==================================="  
        echo " DOMAIN   : $DOMAINZIV"
        echo " REGION   : $isp"
        echo " PASSWOR : $password"
        echo " EXPIRY IN : $EXPIRE_FORMATTED"
        echo "==================================="  
        echo "Terima kasih telah menggunakan layanan kami"

#send to tele
        local message=$(cat <<EOF
===================================
           UDP ZIVPN CREATE
===================================
 DOMAIN   : $DOMAINZIV
 REGION   : $isp
 PASWORD : $password
 EXPIRY IN : $EXPIRE_FORMATTED
===================================
EOF
        )
        send_telegram_notification "$message"
        return 0
    else
        # Jika gagal update config.json, hapus akun dari db
        sed -i "/^${password}:/d" "$db_file"
        echo "Error: Failed to update config.json."
        return 1
    fi
}

################################################################################
#                     BUAT AKUN UDP ZIVPN SECARA MANUAL                        #
################################################################################
function create_manual_account() {
    echo "───────── Create New Zivpn Account ───────"

    # Input password baru
    read -p "Enter new password: " password
    if [ -z "$password" ]; then
        echo "Password cannot be empty."
        return
    fi

    # Input masa aktif
    read -p "Enter active period (in days): " days
    if ! [[ "$days" =~ ^[0-9]+$ ]]; then
        echo "Invalid number of days."
        return
    fi

    # Panggil logic pembuatan akun
    local result
    result=$(_create_account_logic "$password" "$days")

    # Jika berhasil, tampilkan info dari database
    if [[ "$result" == "0" ]]; then
        local db_file="/etc/zivpn/users.db"
        local user_line
        user_line=$(grep "^${password}:" "$db_file")
        if [ -n "$user_line" ]; then
            local expiry_date
            expiry_date=$(echo "$user_line" | cut -d: -f2)
            local CERT_CN HOST EXPIRE_FORMATTED
            CERT_CN=$(openssl x509 -in /etc/zivpn/zivpn.crt -noout -subject | sed -n 's/.*CN = \([^,]*\).*/\1/p')
            if [ "$CERT_CN" == "zivpn" ]; then
                HOST=$(cat /etc/zivpn/ip.txt)
            else
                HOST=$CERT_CN
            fi
            EXPIRE_FORMATTED=$(date -d "@$expiry_date" +"%d %B %Y %H:%M")
        fi
    else
        echo "$result"
    fi

    read -p "Tekan Enter untuk kembali ke menu..."
    m-zivpn
}


################################################################################
#                        GENERATE API KEY OTOMATIS                              #
################################################################################
function _generate_api_key() {
    clear
    echo -e "\e[93;1m─── Generate API Authentication Key ─── \e[0m"

    # Buat API key acak 6 karakter alfanumerik
    local api_key
    api_key=$(LC_ALL=C tr -dc 'a-zA-Z0-9' < /dev/urandom | head -c 6)

    # Simpan API key ke file
    local key_file="/etc/zivpn/api_auth.key"
    echo "$api_key" > "$key_file"
    chmod 600 "$key_file"  # Batasi akses file

    echo -e "\e[96;1m New API authentication key has been generated and saved. \e[0m"
    echo "Key: ${api_key}"

    # Siapkan data untuk notifikasi Telegram
    echo -e "\e[94;1m Sending API key to Telegram... \e[0m"
    local server_ip cert_cn domain
    server_ip=$(cat /etc/zivpn/ip.txt)
    cert_cn=$(openssl x509 -in /etc/zivpn/zivpn.crt -noout -subject \
              | sed -n 's/.*CN = \([^,]*\).*/\1/p' 2>/dev/null || echo "")

    # Tentukan host/domain untuk notifikasi
    if [ "$cert_cn" == "zivpn" ] || [ -z "$cert_cn" ]; then
        domain=$server_ip
    else
        domain=$cert_cn
    fi

    # Kirim API key ke Telegram melalui helper script
    /usr/local/bin/zivpn_helper.sh api-key-notification "$api_key" "$server_ip" "$domain"

    read -p "Tekan Enter untuk kembali ke menu..."
    m-zivpn
}

