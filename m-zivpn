#!/usr/bin/env bash

curl -s ipinfo.io | grep region | cut -d '"' -f4 > /etc/zivpn/isp.txt
DOWNLOAD_ZIVPN() {

set -euo pipefail

BACKUP_DIR="/usr/bin/zivback"
CFG_DIR="/etc/zivpn"
BIN_PATH="/usr/local/bin/zivpn"

KEY_PATH="$CFG_DIR/zivpn.key"
CRT_PATH="$CFG_DIR/zivpn.crt"
CFG_PATH="$CFG_DIR/config.json"

BIN_URL="https://raw.githubusercontent.com/Arya-Blitar22/komtol/main/udp-zivpn-linux-amd64"
CFG_URL="https://raw.githubusercontent.com/Arya-Blitar22/komtol/main/config.json"

UDP_LISTEN_PORT="5667"
DNAT_FROM_MIN="6000"
DNAT_FROM_MAX="19999"

echo "==== BACKUP CONFIG ===="

mkdir -p "$BACKUP_DIR"

if [ -d "$CFG_DIR" ]; then
cp -rf $CFG_DIR/* $BACKUP_DIR/ 2>/dev/null || true
fi

echo "Backup saved -> $BACKUP_DIR"

echo "==== UPDATE SERVER ===="

export DEBIAN_FRONTEND=noninteractive
apt-get update -y
apt-get upgrade -y

echo "==== STOP SERVICE ===="

systemctl stop zivpn 2>/dev/null || true

echo "==== INSTALL BINARY ===="

rm -f "$BIN_PATH"

mkdir -p "$CFG_DIR"

curl -sSL "$BIN_URL" -o "$BIN_PATH"
chmod +x "$BIN_PATH"

echo "==== DOWNLOAD CONFIG ===="

curl -sSL "$CFG_URL" -o "$CFG_PATH"

echo "==== GENERATE CERT ===="

if [[ ! -f "$KEY_PATH" || ! -f "$CRT_PATH" ]]; then
openssl req -new -newkey rsa:4096 -days 365 -nodes -x509 \
-subj "/CN=zivpn" \
-keyout "$KEY_PATH" \
-out "$CRT_PATH"
fi

echo "==== APPLY SYSCTL ===="

cat >/etc/sysctl.d/99-zivpn.conf <<EOF
net.core.rmem_max=16777216
net.core.wmem_max=16777216
net.core.netdev_max_backlog=4096
net.ipv4.udp_rmem_min=8192
net.ipv4.udp_wmem_min=8192
EOF

sysctl --system >/dev/null

echo "==== CREATE SERVICE ===="

cat >/etc/systemd/system/zivpn.service <<EOF
[Unit]
Description=ZIVPN UDP Server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=$CFG_DIR
ExecStart=$BIN_PATH server -c $CFG_PATH
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
EOF

systemctl daemon-reload
systemctl enable zivpn >/dev/null

echo "==== SETUP NAT ===="

apt-get install -y iptables-persistent >/dev/null

DEF_IF=$(ip route | awk '/default/ {print $5; exit}')

iptables -t nat -C PREROUTING -i $DEF_IF -p udp --dport $DNAT_FROM_MIN:$DNAT_FROM_MAX -j DNAT --to-destination :$UDP_LISTEN_PORT 2>/dev/null || \
iptables -t nat -A PREROUTING -i $DEF_IF -p udp --dport $DNAT_FROM_MIN:$DNAT_FROM_MAX -j DNAT --to-destination :$UDP_LISTEN_PORT

iptables-save > /etc/iptables/rules.v4

echo "==== RESTORE BACKUP ===="

if [ -d "$BACKUP_DIR" ]; then
cp -rf $BACKUP_DIR/* $CFG_DIR/ 2>/dev/null || true
fi

echo "Setup watchdog..."

crontab -l 2>/dev/null | grep -v zivpn-watchdog | crontab -

(crontab -l 2>/dev/null; \
echo "*/2 * * * * systemctl is-active --quiet zivpn || systemctl restart zivpn #zivpn-watchdog") | crontab -

echo "==== START SERVICE ===="

systemctl restart zivpn

echo ""
echo "✅ ZIVPN INSTALL COMPLETE"
echo "Port UDP : $UDP_LISTEN_PORT"
echo "DNAT     : $DNAT_FROM_MIN-$DNAT_FROM_MAX"
echo "Service  : systemctl status zivpn"
}



