################################################################################
#                       LOGIKA HAPUS AKUN UDP ZIVPN                             #
################################################################################
function _delete_account_logic() {
    data=$(curl -s ipinfo.io)
    isp=$(echo $data | jq -r '.org')
    local password="$1"                     # Password akun yang akan dihapus
    local db_file="/etc/zivpn/users.db"     # Database akun
    local config_file="/etc/zivpn/config.json"
    local tmp_config_file="${config_file}.tmp"

    # Validasi input
    if [ -z "$password" ]; then
        echo "Error: Password is required."
        return 1
    fi

    # Cek apakah akun ada di database
    if [ ! -f "$db_file" ] || ! grep -q "^${password}:" "$db_file"; then
        echo "Error: Password '${password}' not found."
        return 1
    fi

    # Hapus akun dari config.json menggunakan jq
    jq --arg pass "$password" 'del(.auth.config[] | select(. == $pass))' \
       "$config_file" > "$tmp_config_file"

    if [ $? -eq 0 ]; then
        # Hapus akun dari database
        sed -i "/^${password}:/d" "$db_file"

        # Replace config.json dengan file temp yang sudah diupdate
        mv "$tmp_config_file" "$config_file"

        # Restart service ZIVPN agar perubahan berlaku
        restart_zivpn

        # Ambil info host, IP, ISP, dan certificate
        local ip isp CERT_CN host
        ip=$(cat /etc/zivpn/ip.txt)
        isp=$(cat /etc/zivpn/isp.txt)
        CERT_CN=$(openssl x509 -in /etc/zivpn/zivpn.crt -noout -subject \
                  | sed -n 's/.*CN = \([^,]*\).*/\1/p')
        if [ "$CERT_CN" == "zivpn" ]; then
            host="$ip"
        else
            host="$CERT_CN"
        fi

        # Tampilkan info akun yang dihapus
        clear
        DOMAINZIV=$(cat /etc/xray/domain)        
        echo "==================================="
        echo "          UDP ZIVPN DELETE          "        
        echo "==================================="        
        echo "==================================="  
        echo " DOMAIN   : $DOMAINZIV"
        echo " REGION   : $isp"
        echo " PASWORD: $password"
        echo "==================================="  

        # Kirim notifikasi ke Telegram
        local message=$(cat <<EOF
===================================        
      DELETE UDP ZIVPN ACCOUNT
===================================
 DOMAIN   : $DOMAINZIV
 REGION   : $isp
 PASWORD : $password
===================================
EOF
        )
        send_telegram_notification "$message"
        return 0
    else
        # Jika gagal update config.json, bersihkan file sementara
        rm -f "$tmp_config_file"
        echo "Error: Failed to update config.json. No changes were made."
        return 1
    fi
}

################################################################################
#                   EKSEKUSI LOGIKA HAPUS AKUN UDP ZIVPN                        #
