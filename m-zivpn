################################################################################
#                     LOGIC UNTUK RENEW AKUN UDP ZIVPN                          #
################################################################################
function _renew_account_logic() {
    data=$(curl -s ipinfo.io)
    isp=$(echo $data | jq -r '.org')
    local password="$1"          # Password akun yang ingin diperpanjang
    local days="$2"              # Jumlah hari perpanjangan
    local db_file="/etc/zivpn/users.db"

    # Validasi input
    if [ -z "$password" ] || [ -z "$days" ]; then
        echo "Error: Password and days are required."
        return 1
    fi

    if ! [[ "$days" =~ ^[1-9][0-9]*$ ]]; then
        echo "Error: Invalid number of days."
        return 1
    fi

    # Ambil entry akun dari database
    local user_line
    user_line=$(grep "^${password}:" "$db_file")
    if [ -z "$user_line" ]; then
        echo "Error: Account '${password}' not found."
        return 1
    fi

    # Ambil tanggal kadaluarsa saat ini
    local current_expiry_date
    current_expiry_date=$(echo "$user_line" | cut -d: -f2)
    if ! [[ "$current_expiry_date" =~ ^[0-9]+$ ]]; then
        echo "Error: Corrupted database entry for user '$password'."
        return 1
    fi

    # Hitung tanggal kadaluarsa baru (timestamp)
    local seconds_to_add=$((days * 86400))          # 1 hari = 86400 detik
    local new_expiry_date=$((current_expiry_date + seconds_to_add))

    # Update database dengan tanggal kadaluarsa baru
    sed -i "s/^${password}:.*/${password}:${new_expiry_date}/" "$db_file"

    # Format tanggal kadaluarsa baru untuk tampilan
    local new_expiry_formatted
    new_expiry_formatted=$(date -d "@$new_expiry_date" +"%d %B %Y %H:%M")

    # Ambil info host, IP, ISP, dan certificate
    local ip isp CERT_CN host
    ip=$(cat /etc/zivpn/ip.txt)
    isp=$(cat /etc/zivpn/isp.txt)
    CERT_CN=$(openssl x509 -in /etc/zivpn/zivpn.crt -noout -subject \
              | sed -n 's/.*CN = \([^,]*\).*/\1/p')
    if [ "$CERT_CN" == "zivpn" ]; then
        host="$ip"
    else
        host="$CERT_CN"
    fi

    # Tampilkan info perpanjangan akun
    clear
    DOMAINZIV=$(cat /etc/xray/domain)
        echo "==================================="
        echo "           UDP ZIVPN EXTEND            "        
        echo "==================================="        
        echo "==================================="  
        echo " DOMAIN   : $DOMAINZIV"
        echo " REGION   : $isp"
        echo " PASSWOR : $password"
        echo " EXPIRY IN : $new_expiry_formatted"
        echo "==================================="          

#send to tele
    local message=$(cat <<EOF
===================================
        UDP ZIVPN EXTEND
===================================
 DOMAIN   : $DOMAINZIV
 REGION   : $isp
 PASWORD : $password
 EXPIRY IN : $EXPIRE_FORMATTED
===================================
EOF
    )
    send_telegram_notification "$message"
    return 0
}

